APP_NAME=TimeEcho
APP_ENV=dev
TIMEECHO_DEBUG=false
API_PREFIX=/api

DATABASE_URL=postgresql+asyncpg://timeecho:timeecho@postgres:5432/timeecho
REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=change-this-jwt-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=14

SERVER_SALT=change-this-server-salt
ENCRYPTION_SECRET=change-this-encryption-secret-at-least-32-chars

DEV_SMS_CODE=123456
PHONE_AUTO_REGISTRATION_ENABLED=false

# Official email verification. Keep development mode enabled until SMTP works.
EMAIL_VERIFICATION_REQUIRED=false
EMAIL_ALLOW_UNVERIFIED_REGISTRATION=true
EMAIL_DEV_CODE_ENABLED=true
DEV_EMAIL_CODE=123456
EMAIL_CODE_EXPIRE_MINUTES=10
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=TimeEcho
SMTP_USE_TLS=true
SMTP_USE_SSL=false

DAILY_LETTER_LIMIT=3
DAILY_SALVAGE_LIMIT=5
DAILY_COMPLAINT_LIMIT=10
CHAT_MESSAGE_LIMIT_PER_MINUTE=3

ROOM_TTL_HOURS=24
DORMANT_AFTER_DAYS=7

# Optional UI preview served at /
APP_STATIC_UI=true

# Production must additionally set strong POSTGRES_PASSWORD and REDIS_PASSWORD,
# enable EMAIL_VERIFICATION_REQUIRED, and disable every DEV_* / simulation flag.
# Create administrators in the database with scripts/create_admin.py; there is
# intentionally no administrator password environment variable.
